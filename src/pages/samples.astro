---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Samples';
const description = 'Sample Code';
const permalink = `${Astro.site.href}samples`;

---

<BaseLayout title={title} description={description} permalink={permalink} current="samples">
  <div class="container">
    <h1>Downloads</h1>
    <h2>Cross-Platform - C# .Net Core 9.x</h2>
    <p>
    
    <ul>
       {downloads.map(d => (
        <li>
          <strong>{d.name}</strong> ({d.version}) — {d.size}
          <br />
          <a href={d.file} download>Download</a><br>
          For more info see: <a href={d.info}>Installation notes and screen shots</a>
        </li>
      ))}

    </ul>
    </p>
</BaseLayout>

<style>
  .about-image {
    float: right;
    margin: -3em -7em 2em 2em;
    max-width: 300px;
  }

  .about-image img {
    border-radius: 8px;
    margin-bottom: 1.5em;
  }

  @media (max-width: 1020px) {
    .about-image {
      float: none;
      margin: 0 auto 2em;
    }
  }
</style>
